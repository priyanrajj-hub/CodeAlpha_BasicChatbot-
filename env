# ─────────────────────────────────────────
# AlphaBot Configuration Template
# Copy this file: cp .env.example .env
# Then fill in your values below.
# ─────────────────────────────────────────

# Your Anthropic API key (get from https://console.anthropic.com)
# Leave blank to run in rule-based offline mode.
API_KEY=""

# Bot and user display names
BOT_NAME="AlphaBot"
USER_NAME="Developer"

# Model to use (don't change unless needed)
MODEL="claude-sonnet-4-20250514"

# Max tokens per AI response (100–4096)
MAX_TOKENS="1000"

# Max conversation history messages to send to AI (keeps costs low)
MAX_HISTORY="20"
